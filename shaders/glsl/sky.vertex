#version 100

precision highp float;

attribute vec3 POSITION;
attribute vec4 COLOR;

varying vec4 vColor;
varying vec3 vPosition;

uniform mat4 PROJECTION;
uniform mat4 MODELVIEW;
uniform float TIME;

void main() {
    gl_Position = PROJECTION * MODELVIEW * vec4(POSITION, 1.0);
    vPosition = POSITION;
    vColor = COLOR;
}
